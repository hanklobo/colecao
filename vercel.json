{
  "rewrites": [
    { "source": "/((?!api/|copa-2026/|.*\\..*).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": { "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
